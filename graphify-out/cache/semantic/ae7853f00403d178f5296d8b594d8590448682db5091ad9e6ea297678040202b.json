{"nodes": [{"id": "research_prompt_engineering_gps_framework_gps_framework", "label": "GPS Framework", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "GPS breaks the vending-machine habit of one prompt, one answer. Most people treat AI like a vending machine; GPS turns them into someone who produces with AI."}, {"id": "research_prompt_engineering_gps_framework_gaslight", "label": "Gaslight", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "AI models were trained on billions of words of human language carrying emotional weight. When stakes go up in text, model attention goes up. Betting language is associated with high-stakes situations, so the model slows down and double-checks."}, {"id": "research_prompt_engineering_gps_framework_push_back", "label": "Push Back", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "AI was designed to be a people-pleaser, trained with human feedback to keep users happy. Accepting the first answer yields average thinking; challenging it yields structured thinking and usable insights."}, {"id": "research_prompt_engineering_gps_framework_stress_test", "label": "Stress Test", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "Separates top 1% of AI users from everyone else. It is not what you ask AI, but what you do AFTER it answers. A 3-step 90-second audit on every important output."}, {"id": "research_prompt_engineering_gps_framework_gap_check", "label": "Gap Check", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "Ask the AI what it needed to know before answering. Make it coach you into a better question."}, {"id": "research_prompt_engineering_gps_framework_bias_sweep", "label": "Bias Sweep", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "Make the AI audit its own reasoning for common cognitive biases before you act on the recommendation."}, {"id": "research_prompt_engineering_gps_framework_inject_real_stakes", "label": "Inject Real Stakes", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "Name the exact consequence of being wrong. Force the AI to re-examine its recommendation under real-world pressure."}, {"id": "research_prompt_engineering_gps_framework_vaibhav_sisinty", "label": "Vaibhav Sisinty", "file_type": "concept", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null}, {"id": "research_prompt_engineering_gps_framework_prompt_engineer_master", "label": "Prompt Engineer Master", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null, "rationale": "Teaches process mastery in prompt design across different AI models and contexts. Focus is on clarity, structure, adaptability, and optimization."}, {"id": "research_prompt_engineering_gps_framework_confirmation_bias", "label": "Confirmation Bias", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null}, {"id": "research_prompt_engineering_gps_framework_recency_bias", "label": "Recency Bias", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null}, {"id": "research_prompt_engineering_gps_framework_survivorship_bias", "label": "Survivorship Bias", "file_type": "rationale", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null}, {"id": "research_prompt_engineering_gps_framework_gps_prompt_engineer_skill", "label": "GPS Prompt Engineer Skill", "file_type": "concept", "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Miles Deutscher / Vaibhav Sisinty", "contributor": null}], "edges": [{"source": "research_prompt_engineering_gps_framework_gps_framework", "target": "research_prompt_engineering_gps_framework_gaslight", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Memory/research/prompt-engineering-gps-framework.md", "source_location": null, "weight": 1.0}, {"source": "research_prompt_engineering_gps_framework_gps_