# Zero Brain — Environment Template
# Copy this file to `.env` in the project root and fill in your real values.
# NEVER commit `.env` to Git. It is protected by `.gitignore`.

# Gmail OAuth2 Desktop App
credentials.json=path/to/your/credentials.json

# Slack Bot Token (xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App Token (xapp-)
SLACK_APP_TOKEN=xapp-your-app-token-here

# GitHub Fine-Grained PAT
GITHUB_TOKEN=ghp_your_pat_here

# Linear API Key
LINEAR_API_KEY=lin_api_your_key_here

# Anthropic API Key (for Claude Code Review workflow)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key (if using GPT models)
OPENAI_API_KEY=sk-your-key-here
